# ===================================
# CONFIGURACIÓN - PostgreSQL + Cloud Run
# ===================================

# AMBIENTE
ENVIRONMENT=development

# SEGURIDAD
JWT_SECRET=development-only-change-me
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480

# BASE DE DATOS - PostgreSQL (Desarrollo local)
# Opcional: sobrescribe toda la conexión con una URL directa.
# DATABASE_URL=sqlite:///./local.db
DB_USER=postgres
DB_PASSWORD=tu_contraseña_segura
DB_HOST=localhost
DB_PORT=5432
DB_NAME=edem_hub_db

# ===================================
# Para CLOUD RUN + Cloud SQL
# ===================================
# En Cloud Run, usa estas variables en lugar de las anteriores:
# ENVIRONMENT=production
# JWT_SECRET=<secreto_jwt_largo_y_aleatorio>
# DB_USER=postgres
# DB_PASSWORD=<tu_contraseña_de_cloud_sql>
# CLOUD_SQL_CONNECTION_NAME=/cloudsql/mi-proyecto:us-central1:mi-instancia-sql
# DB_NAME=edem_hub_db
#
# Las credenciales deben ser configuradas en Google Cloud Secret Manager
# y luego referenciadas en Cloud Run Environment Variables

# ENVIRONMENT=development
# DB_HOST=postgres
# DB_PORT=5432
# DB_NAME=edem_hub_db
# DB_USER=postgres
# DB_PASSWORD=postgres
# JWT_SECRET=dev-secret-cambiame-en-produccion
# JWT_ALGORITHM=HS256
# ACCESS_TOKEN_EXPIRE_MINUTES=480
# FRONTEND_URL=http://localhost:5173