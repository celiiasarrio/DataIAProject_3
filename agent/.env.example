# Backend FastAPI a consumir
BACKEND_BASE_URL=http://localhost:8080

# Modelo
MODEL=gemini-2.5-flash

# --- Opción A: Vertex AI (recomendado en GCP) ---
# Requiere `gcloud auth application-default login`
GOOGLE_GENAI_USE_VERTEXAI=TRUE
GOOGLE_CLOUD_PROJECT=edem-hackathon-2026
GOOGLE_CLOUD_LOCATION=europe-west1

# --- Opción B: Gemini API (más rápido para arrancar en local) ---
# Pon USE_VERTEXAI=FALSE y descomenta la API key
# GOOGLE_GENAI_USE_VERTEXAI=FALSE
# GOOGLE_API_KEY=tu-api-key

# Timeout HTTP para las tools contra el backend
HTTP_TIMEOUT_SECONDS=15

# Firestore (vacío = desactivar memoria persistente en el PoC local)
FIRESTORE_PROJECT=
FIRESTORE_DATABASE=(default)